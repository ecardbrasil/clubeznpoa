# Runtime data provider: use "supabase" in production-like mode or "local" for demo mode.
NEXT_PUBLIC_DATA_PROVIDER=supabase

# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# API session signing secret (use a strong random value)
API_SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
